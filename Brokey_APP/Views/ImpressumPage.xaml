<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Brokey_APP.Views.ImpressumPage"
             Title="Impressum"
             BackgroundColor="{StaticResource BrokeyBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="25,20" Spacing="20">

            <!-- Header -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,10,0,10">
                <Image Source="brokey_mascot.png"
                       HeightRequest="80"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"/>
                <Label Text="Impressum"
                       FontFamily="PoppinsBold"
                       FontSize="26"
                       TextColor="{StaticResource BrokeyDarkBlue}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Impressum Content -->
            <Border BackgroundColor="{StaticResource White}"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="24">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Gray300Brush}" Offset="0,2" Radius="8" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="20">

                    <!-- Project Info -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Project"
                               FontFamily="PoppinsSemiBold"
                               FontSize="16"
                               TextColor="{StaticResource BrokeyDarkBlue}"/>
                        <Label Text="Brokey — Your Travel Expense Companion"
                               FontFamily="PoppinsRegular"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                    <!-- Developer -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Developer"
                               FontFamily="PoppinsSemiBold"
                               FontSize="16"
                               TextColor="{StaticResource BrokeyDarkBlue}"/>
                        <Label Text="Gabriel Winkler"
                               FontFamily="PoppinsRegular"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                    <!-- Class -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Class"
                               FontFamily="PoppinsSemiBold"
                               FontSize="16"
                               TextColor="{StaticResource BrokeyDarkBlue}"/>
                        <Label Text="4BHWII"
                               FontFamily="PoppinsRegular"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                    <!-- School -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="School"
                               FontFamily="PoppinsSemiBold"
                               FontSize="16"
                               TextColor="{StaticResource BrokeyDarkBlue}"/>
                        <Label Text="HTL Anichstraße"
                               FontFamily="PoppinsRegular"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}"/>
                        <Label Text="Anichstraße 26-28"
                               FontFamily="PoppinsRegular"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"/>
                        <Label Text="6020 Innsbruck, Austria 🇦🇹"
                               FontFamily="PoppinsRegular"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                    <!-- Year -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Year"
                               FontFamily="PoppinsSemiBold"
                               FontSize="16"
                               TextColor="{StaticResource BrokeyDarkBlue}"/>
                        <Label Text="2025 / 2026"
                               FontFamily="PoppinsRegular"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Footer -->
            <Label Text="Made with ❤️ in Innsbruck"
                   FontFamily="PoppinsRegular"
                   FontSize="13"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center"
                   Margin="0,10,0,30"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

