<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Brokey_APP.ViewModels"
             x:Class="Brokey_APP.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile"
             BackgroundColor="{StaticResource BrokeyBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="25,20" Spacing="20">

            <!-- Profile Header -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,20,0,10">
                <!-- Avatar Circle -->
                <Border BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 50"
                        Stroke="Transparent"
                        WidthRequest="100"
                        HeightRequest="100"
                        HorizontalOptions="Center">
                    <Image Source="brokey_mascot.png"
                           HeightRequest="70"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="{Binding Username}"
                       FontFamily="PoppinsBold"
                       FontSize="22"
                       TextColor="{StaticResource BrokeyDarkBlue}"
                       HorizontalOptions="Center"/>
                <Label Text="{Binding Email}"
                       FontFamily="PoppinsRegular"
                       FontSize="14"
                       TextColor="{StaticResource Gray500}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Info Cards -->
            <Border BackgroundColor="{StaticResource White}"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Padding="20">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Gray300Brush}" Offset="0,2" Radius="8" Opacity="0.12"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <!-- Currency -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="💱" FontSize="22" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Base Currency"
                                   FontFamily="PoppinsSemiBold"
                                   FontSize="14"
                                   TextColor="{StaticResource BrokeyDarkBlue}"/>
                            <Label Text="{Binding BaseCurrency}"
                                   FontFamily="PoppinsRegular"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource Gray300}" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                    <!-- Groups -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="👥" FontSize="22" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="My Groups"
                                   FontFamily="PoppinsSemiBold"
                                   FontSize="14"
                                   TextColor="{StaticResource BrokeyDarkBlue}"/>
                            <Label Text="Manage your travel groups"
                                   FontFamily="PoppinsRegular"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource Gray300}" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>

                    <!-- Settings -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="⚙️" FontSize="22" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0">
                            <Label Text="Settings"
                                   FontFamily="PoppinsSemiBold"
                                   FontSize="14"
                                   TextColor="{StaticResource BrokeyDarkBlue}"/>
                            <Label Text="App preferences"
                                   FontFamily="PoppinsRegular"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource Gray300}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Logout Button -->
            <Button Text="Logout"
                    Style="{StaticResource SecondaryButton}"
                    BorderColor="#FF6B6B"
                    TextColor="#FF6B6B"
                    Command="{Binding LogoutCommand}"
                    HorizontalOptions="Fill"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

